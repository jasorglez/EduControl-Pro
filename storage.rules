rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Task attachments uploaded by teachers
    match /{schoolId}/tasks/{taskId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Student submission files (uploaded by bot server via Admin SDK)
    match /{schoolId}/submissions/{submissionId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
